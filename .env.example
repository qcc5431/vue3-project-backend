# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=vue3_backend

# JWT配置
JWT_SECRET=your_jwt_secret_key_change_me
JWT_EXPIRES_IN=7d

# 腾讯云COS配置
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_BUCKET=web-front-1360774249
COS_REGION=ap-beijing

# ─── 短信配置 ───────────────────────────────────────────────
# SMS_MODE 可选值：mock（默认，验证码打印到控制台）| tencent | smsbao
SMS_MODE=mock

# 腾讯云短信（SMS_MODE=tencent 时启用）
# 需先安装: npm install tencentcloud-sdk-nodejs-sms
TENCENT_SECRET_ID=your_tencent_secret_id
TENCENT_SECRET_KEY=your_tencent_secret_key
TENCENT_SMS_APP_ID=your_sms_sdk_app_id
TENCENT_SMS_SIGN=your_sms_sign_name
TENCENT_SMS_TEMPLATE_ID=your_template_id

# 短信宝（SMS_MODE=smsbao 时启用，无需额外安装依赖）
# 注册地址: https://www.smsbao.com
SMSBAO_USERNAME=your_smsbao_phone
SMSBAO_PASSWORD=your_smsbao_password
SMSBAO_SIGN=【您的应用名称】
